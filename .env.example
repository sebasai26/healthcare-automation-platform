# Variables de Entorno de Ejemplo para Marbella Fisio

# ID del proyecto de Supabase
VITE_SUPABASE_PROJECT_ID="tu_supabase_project_id"

# URL de la API REST de Supabase
VITE_SUPABASE_URL="https://tu_supabase_project_id.supabase.co"

# Clave pública Anon/Publishable de Supabase para peticiones de cliente
VITE_SUPABASE_PUBLISHABLE_KEY="tu_supabase_anon_key"

# Clave de API de Google Gemini para las funciones y consejos de IA (opcional en local, requerida para IA)
VITE_GEMINI_API_KEY="tu_gemini_api_key"
